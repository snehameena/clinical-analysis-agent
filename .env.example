# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Model/provider configuration is defined in config/agents.yaml (config-only).
# The *_MODEL env vars are deprecated and are not used by the codebase anymore.

# Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_URL=http://localhost:8000

# Pipeline Configuration
MAX_QUALITY_ITERATIONS=3
TAVILY_MAX_RESULTS_PER_QUERY=5
TAVILY_MIN_RELEVANCE_SCORE=0.6

# Logging
LOG_LEVEL=INFO
